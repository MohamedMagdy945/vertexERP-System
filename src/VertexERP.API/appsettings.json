{
  "Application": {
    "Name": "VertexERP.API"
  },

  "LoggingSetting": {
    "UseConsole": true,
    "UseSeq": true,
    "UseElasticsearch": false,

    "SeqUrl": "http://localhost:5341",
    "ElasticsearchUrl": "http://elasticsearch:9200"
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Enrichers.MachineName",
      "Serilog.Exceptions"
    ],

    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },

    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithExceptionDetails"
    ],

    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  }
}