{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "VertexERP.API.Middlewares.GlobalExceptionHandler": "Error"
      }

    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Properties": {
      "Application": "LoggingTemplate"
    }
  },
  "TokenPairSettings": {
    "SecretKey": "Mods@wer@321U$#%asd!,@312322LKKKLldMdKL!@##$^",
    "Audience": "https://localhost:4200/",
    "Issuer": "https://localhost:5000/",
    "AccessTokenExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 30
  },

  "AllowedHosts": "*"
}
